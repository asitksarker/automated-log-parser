# Ignore real server logs that might contain PII or credentials
*.log
!sample_logs.log

# Ignore generated threat intelligence/results
blocklist.csv
threat_report.json
*.db
*.sqlite3

# Ignore credentials and API keys
.env
secrets.py
config.yaml
auth.json

